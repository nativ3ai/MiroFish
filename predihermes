#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_BIN="$ROOT_DIR/backend/.venv/bin/python"

if [[ -x "$PYTHON_BIN" ]]; then
  exec "$PYTHON_BIN" "$ROOT_DIR/tmp_geopolitical_market_pipeline.py" "$@"
fi

exec python3 "$ROOT_DIR/tmp_geopolitical_market_pipeline.py" "$@"
