# 本地 LLM 配置（默认推荐 Ollama + Qwen）
LLM_API_KEY=ollama
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL_NAME=qwen2.5:7b
LOCAL_LLM_REQUEST_TIMEOUT_SECONDS=900
LOCAL_LLM_MAX_RETRIES=1
LOCAL_LLM_MAX_TOKENS=192
LOCAL_LLM_TEMPERATURE=0.2
FLASK_DEBUG=False

# ===== 图谱后端配置 =====
# 可选值: auto | local | zep
# local: 使用 backend/uploads/graphs/*.sqlite3 本地图谱，不依赖 Zep
# auto:  若存在 ZEP_API_KEY 则走 Zep，否则自动回退到 local
# zep:   强制使用 Zep 图谱后端
GRAPH_BACKEND=local
LOCAL_GRAPH_EXTRACTION_MODE=fast
LOCAL_SIMULATION_PROFILE=lean
LOCAL_SIM_MAX_AGENTS=48
LOCAL_SIM_INITIAL_POST_LIMIT=2
LOCAL_SIM_AGENTS_PER_HOUR_MIN=3
LOCAL_SIM_AGENTS_PER_HOUR_MAX=8
LOCAL_SIM_MAX_ROUNDS=16
LOCAL_SIM_PARALLEL_PROFILE_COUNT=3

# ===== ZEP记忆图谱配置 =====
# 仅在 GRAPH_BACKEND=zep 时必需：https://app.getzep.com/
# ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
# LLM_BOOST_API_KEY=ollama
# LLM_BOOST_BASE_URL=http://127.0.0.1:11434/v1
# LLM_BOOST_MODEL_NAME=qwen2.5:7b
